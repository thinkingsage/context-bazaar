{
  "name": "brand-consistency-check",
  "version": "1.0.0",
  "description": "When an author-facing document is saved (bio, website copy, social media content, newsletter), scan for consistency with the established author brand — voice, messaging, visual identity references, and public persona.",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "**/brand/**",
      "**/platform/**",
      "**/marketing/**",
      "**/bio*",
      "**/newsletter*",
      "**/website*"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "An author-facing document was just saved. Scan for brand consistency: (1) Does the voice match the established author brand and tone? (2) Are key messaging points present and consistent? (3) Is the author bio aligned with the current version? (4) Are visual identity references (colors, fonts, logo usage) consistent if mentioned? (5) Does the public persona feel coherent with other published materials? Flag any drift from the established brand."
  }
}
