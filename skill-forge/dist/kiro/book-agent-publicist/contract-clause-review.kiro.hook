{
  "name": "contract-clause-review",
  "version": "1.0.0",
  "description": "User-triggered hook to run the contract review checklist against the current document — rights granted, financial terms, option clause, non-compete, reversion, and protective clauses.",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Run the contract review checklist against the current document. Check: Rights Granted (territory, subsidiary rights, audio, film/TV, foreign), Financial Terms (advance, royalties, e-book rate, reserve against returns, joint accounting), Option Clause (scope, deadline, matching right vs. first refusal), Non-Compete (breadth, duration, self-publishing carve-out), Reversion (sales threshold, trigger mechanism), Delivery (acceptance criteria, cure period), and Other (copyright ownership, cover consultation, audit rights, assignment consent, warranty/indemnification). Flag any clause that is missing, overly broad, or unfavorable to the author."
  }
}
