{
  "name": "deal-terms-comparison",
  "version": "1.0.0",
  "description": "After a deal negotiation task completes, produce a structured summary comparing the offered terms against standard industry benchmarks for the genre and deal level.",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "The deal negotiation task is complete. Produce a structured comparison of the offered terms against standard industry benchmarks: advance amount and payout schedule, hardcover/paperback/e-book royalty rates, subsidiary rights retained vs. granted, option clause scope, non- compete breadth, reversion threshold, and any unusual clauses. Note which terms are favorable, standard, or below market. This is not legal advice — recommend consulting a publishing attorney for significant deals."
  }
}
