{
  "name": "publicity-timeline-check",
  "version": "1.0.0",
  "description": "User-triggered hook to audit the publicity plan timeline against the publication date — flagging any tasks that are overdue, approaching deadline, or missing from the plan.",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Audit the publicity plan timeline against the publication date. Check: Are ARCs distributed (4 months out)? Long-lead media pitched (4 months)? Short-lead media pitched (2 months)? Launch events confirmed (2 months)? Social media content calendar ready (1 month)? Personal network briefed (1 month)? Press kit complete and hosted? Flag any tasks that are overdue, approaching deadline, or missing entirely. Suggest a catch-up plan for anything behind schedule."
  }
}
