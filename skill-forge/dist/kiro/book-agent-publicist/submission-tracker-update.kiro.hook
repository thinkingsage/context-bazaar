{
  "name": "submission-tracker-update",
  "version": "1.0.0",
  "description": "After a query campaign task completes, remind the agent to update the submission tracker with batch number, agents queried, dates sent, materials included, and current response summary.",
  "when": {
    "type": "postTaskExecution"
  },
  "then": {
    "type": "askAgent",
    "prompt": "The query campaign task is complete. Update the submission tracker with: batch number, each agent queried (name, agency, method), date sent, materials included, and current response status. Then produce a response summary — total queries sent, requests for partial, requests for full, personalized rejections, form rejections, no responses, and pending. Flag if the request rate suggests the query letter needs revision."
  }
}
